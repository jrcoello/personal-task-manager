# Copia este archivo como .env para desarrollo local con `netlify dev`.
# NUNCA subas el archivo .env real a git (ya está en .gitignore).

# Personal Access Token de Airtable con scopes:
#   data.records:read, data.records:write
# y acceso concedido a la base apps6HOqFYkoY4AGu.
AIRTABLE_TOKEN=pat_xxxxxxxxxxxxxxxxx

# Opcionales: por defecto ya apuntan a tu base/tabla, solo cámbialos si migras de base.
# NO los configures en Netlify (ya tienen default en el código); si los marcas como
# "secret" ahí, el escaneo de secretos de Netlify falla porque estos mismos valores
# están hardcodeados como fallback en netlify/functions/airtable.js.
AIRTABLE_BASE_ID=apps6HOqFYkoY4AGu
AIRTABLE_TABLE_ID=tblH0j0Lj9vN7oD53

# Opcional: protege todo el sitio con HTTP Basic Auth (usuario/contraseña del navegador).
# Si dejas SITE_PASSWORD vacío o sin definir, el sitio queda sin protección.
SITE_USER=admin
SITE_PASSWORD=
